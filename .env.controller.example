# PicoClaw Controller Node - Environment Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# Image Configuration
# =============================================================================
PICOCLAW_IMAGE=ghcr.io/brendantza/picoclaw:latest

# =============================================================================
# AI Model Configuration
# =============================================================================
# Primary model to use
PICOCLAW_AGENTS_DEFAULTS_MODEL_NAME=kimi-k2.5

# Kimi Coding API credentials
PICOCLAW_PROVIDERS_KIMI_CODING_API_KEY=sk-your-api-key-here
PICOCLAW_PROVIDERS_KIMI_CODING_API_BASE=https://api.kimi.com/coding
# PICOCLAW_PROVIDERS_KIMI_CODING_PROXY=  # Optional: HTTP proxy

# =============================================================================
# Team Configuration (Optional)
# =============================================================================
# Set these if you want this controller to also act as an agent in a team
# Leave empty to run as a standalone controller

# Team ID to join (e.g., my-team-abc123)
PICOCLAW_TEAM_ID=

# Team key for authentication (pk_team_...)
# SECURITY: Keep this secret! Anyone with this key can join your team.
PICOCLAW_TEAM_KEY=

# Role this agent will play in the team
# Options: frontend, backend, fullstack, qa, devops, worker (default)
PICOCLAW_AGENT_ROLE=worker

# Gateway address (usually the controller itself)
PICOCLAW_GATEWAY_ADDRESS=http://localhost:18790

# =============================================================================
# System Configuration
# =============================================================================
TZ=America/New_York
