# ── LLM Provider ──────────────────────────
# Uncomment and set the API key for your provider
# OPENROUTER_API_KEY=sk-or-v1-xxx
# ZHIPU_API_KEY=xxx
# ANTHROPIC_API_KEY=sk-ant-xxx
# OPENAI_API_KEY=sk-xxx
# GEMINI_API_KEY=xxx
# CEREBRAS_API_KEY=xxx

# ── Kimi Coding (uses Anthropic Messages API) ─
# PICOCLAW_PROVIDERS_KIMI_CODING_API_KEY=your-kimi-api-key
# PICOCLAW_PROVIDERS_KIMI_CODING_API_BASE=https://api.kimi.com/coding
# PICOCLAW_PROVIDERS_KIMI_CODING_PROXY=http://proxy:8080

# ── Default Model ─────────────────────────
# PICOCLAW_AGENTS_DEFAULTS_MODEL_NAME=kimi-k2.5

# ── Chat Channel ──────────────────────────
# TELEGRAM_BOT_TOKEN=123456:ABC...
# DISCORD_BOT_TOKEN=xxx
# LINE_CHANNEL_SECRET=xxx
# LINE_CHANNEL_ACCESS_TOKEN=xxx

# ── Web Search (optional) ────────────────
# BRAVE_SEARCH_API_KEY=BSA...

# ── Timezone ──────────────────────────────
TZ=Asia/Shanghai
